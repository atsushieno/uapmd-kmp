package = uapmd
headers = c-api/uapmd-c-common.h c-api/uapmd-c-api.h c-api/uapmd-c-data.h c-api/uapmd-c-engine.h c-api/uapmd-c-tooling.h c-api/uapmd-c-file.h c-api/uapmd-c-gui.h c-api/uapmd-c-app.h
headerFilter = c-api/**

# Link options: add the pre-built uapmd-c-api static library when building the final binary.
# Configure these in build.gradle.kts via linkerOpts or staticLibraries depending on the target.
# Example (macOS/iOS cmake-build-debug):
#   linkerOpts = -L/path/to/cmake-build-debug/c-api -luapmd-c-api -lstdc++
